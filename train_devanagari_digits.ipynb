      "Epoch 13 | train loss 0.0126 acc 0.9971 | val loss 0.0116 acc 0.9982\n",
      "Epoch 14 | train loss 0.0107 acc 0.9988 | val loss 0.0105 acc 0.9994  <-- best\n",
      "Epoch 15 | train loss 0.0108 acc 0.9985 | val loss 0.0108 acc 0.9994\n",
      "\n",
      "Best validation accuracy: 0.9994\n",
      "Saved best_model.pt\n"
     ]
    }
   ],
   "source": [
    "criterion = nn.CrossEntropyLoss(label_smoothing=0.05)\n",
    "optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=NUM_EPOCHS)\n",
    "\n",
    "\n",
    "def run_epoch(loader, train=False):\n",
    "    model.train(train)\n",
    "    total, correct, loss_sum = 0, 0, 0.0\n",
    "    ctx = torch.enable_grad() if train else torch.no_grad()\n",
    "    with ctx:\n",
    "        for batch in loader:\n",
    "            imgs, labels = batch[0].to(DEVICE), batch[1].to(DEVICE)\n",
    "            logits = model(imgs)\n",
    "            loss = criterion(logits, labels)\n",
    "            if train:\n",
    "                optimizer.zero_grad()\n",
    "                loss.backward()\n",
    "                torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "                optimizer.step()\n",
    "            loss_sum += loss.item() * imgs.size(0)\n",
    "            preds = logits.argmax(1)\n",
    "            correct += (preds == labels).sum().item()\n",
    "            total += imgs.size(0)\n",
    "    return loss_sum / total, correct / total\n",
    "\n",
    "\n",
    "history = {'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': []}\n",
    "best_val_acc, best_state = 0.0, None\n",
    "\n",
    "for epoch in range(1, NUM_EPOCHS + 1):\n",
    "    tr_loss, tr_acc = run_epoch(train_loader, train=True)\n",
    "    va_loss, va_acc = run_epoch(val_loader,   train=False)\n",
    "    scheduler.step()\n",
    "    history['train_loss'].append(tr_loss); history['train_acc'].append(tr_acc)\n",
    "    history['val_loss'].append(va_loss);   history['val_acc'].append(va_acc)\n",
    "    flag = ''\n",
    "    if va_acc > best_val_acc:\n",
    "        best_val_acc = va_acc\n",
    "        best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}\n",
    "        flag = '  <-- best'\n",
    "    print(f'Epoch {epoch:02d} | train loss {tr_loss:.4f} acc {tr_acc:.4f} '\n",
    "          f'| val loss {va_loss:.4f} acc {va_acc:.4f}{flag}')\n",
    "\n",
    "print(f'\\nBest validation accuracy: {best_val_acc:.4f}')\n",
    "model.load_state_dict(best_state)  # restore best weights\n",
    "\n",
    "# Save weights so you can reload without retraining\n",
    "torch.save(best_state, 'best_model.pt')\n",
    "print('Saved best_model.pt')\n"
   ]
  },
