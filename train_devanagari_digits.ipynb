   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# IIVP 2026 - Hindi (Devanagari) to Latin Digit Classifier\n",
    "\n",
    "A PyTorch baseline that learns to map a 32x32 grayscale image of a handwritten\n",
    "**Devanagari digit** to its corresponding **Latin digit** label (0-9).\n",
    "\n",
    "\n",
    "Output: `submission.csv` with `Id,Category`.\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "PyTorch 2.5.1 | CUDA available: False\n"
     ]
    }
   ],
   "source": [
    "import os\n",
    "import random\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "from torchvision import transforms\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import confusion_matrix, classification_report\n",
    "\n",
    "print('PyTorch', torch.__version__, '| CUDA available:', torch.cuda.is_available())\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Config"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Using device: mps\n"
     ]
    }
   ],
   "source": [
    "# Paths - adjust DATA_DIR if you move the notebook\n",
    "DATA_DIR   = Path('.')                        # folder containing train.csv, test.csv, train/, test/\n",
    "TRAIN_DIR  = DATA_DIR / 'train' / 'train'     # train/train/{0..9}/*.png\n",
    "TEST_DIR   = DATA_DIR / 'test'  / 'test'      # test/test/*.png\n",
    "TRAIN_CSV  = DATA_DIR / 'train.csv'\n",
    "TEST_CSV   = DATA_DIR / 'test.csv'\n",
    "SUBMISSION = DATA_DIR / 'submission.csv'\n",
    "\n",
    "# Reproducibility\n",
    "SEED = 42\n",
    "random.seed(SEED); np.random.seed(SEED)\n",
    "torch.manual_seed(SEED); torch.cuda.manual_seed_all(SEED)\n",
    "\n",
    "# Hyperparameters\n",
    "IMG_SIZE     = 32\n",
    "NUM_CLASSES  = 10\n",
    "BATCH_SIZE   = 128\n",
    "NUM_EPOCHS   = 25\n",
    "LR           = 7e-4\n",
    "WEIGHT_DECAY = 1e-4\n",
    "VAL_FRAC     = 0.1\n",
    "NUM_WORKERS  = 0\n",
    "\n",
    "DEVICE = torch.device('cuda' if torch.cuda.is_available() else\n",
    "                      ('mps' if torch.backends.mps.is_available() else 'cpu'))\n",
    "print('Using device:', DEVICE)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Dataset\n",
    "\n",
    "Images are 32x32 8-bit grayscale PNGs. The training set is laid out as\n",
    "`train/train/{class}/{id}.png`. We rely on `train.csv` for the (Id, Category)\n",
    "mapping so we can do a stratified split.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "metadata": {},
   "outputs": [],
   "source": [
    "class DevanagariDigitsDataset(Dataset):\n",
    "    \"\"\"Reads images from train/train/{class}/{id}.png using train.csv.\"\"\"\n",
    "    def __init__(self, df, root_dir, transform=None, has_labels=True):\n",
    "        self.df = df.reset_index(drop=True)\n",
    "        self.root = Path(root_dir)\n",
    "        self.transform = transform\n",
    "        self.has_labels = has_labels\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.df)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        row = self.df.iloc[idx]\n",
    "        img_id = int(row['Id'])\n",
    "        if self.has_labels:\n",
    "            label = int(row['Category'])\n",
    "            path = self.root / str(label) / f'{img_id}.png'\n",
    "        else:\n",
    "            path = self.root / f'{img_id}.png'\n",
    "        img = Image.open(path).convert('L')   # grayscale\n",
    "        if self.transform is not None:\n",
    "            img = self.transform(img)\n",
    "        if self.has_labels:\n",
    "            return img, label, img_id\n",
    "        return img, img_id\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Transforms & DataLoaders"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "train.csv: 17,000 rows | test.csv: 3,000 rows\n",
      "Train split: 15,300 | Val split: 1,700\n"
     ]
    }
   ],
   "source": [
    "# Devanagari digits in this dataset have white strokes on black background.\n",
    "# Light augmentations help generalisation without breaking digit identity.\n",
    "train_tfm = transforms.Compose([\n",
    "    transforms.RandomAffine(degrees=10, translate=(0.08, 0.08), scale=(0.9, 1.1)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.5], std=[0.5]),\n",
    "])\n",
    "eval_tfm = transforms.Compose([\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.5], std=[0.5]),\n",
    "])\n",
    "\n",
    "# Stratified train/val split\n",
    "train_df = pd.read_csv(TRAIN_CSV)\n",
    "test_df  = pd.read_csv(TEST_CSV)\n",
    "print(f'train.csv: {len(train_df):,} rows | test.csv: {len(test_df):,} rows')\n",
    "\n",
    "tr_df, va_df = train_test_split(\n",
    "    train_df, test_size=VAL_FRAC, stratify=train_df['Category'],\n",
    "    random_state=SEED,\n",
    ")\n",
    "print(f'Train split: {len(tr_df):,} | Val split: {len(va_df):,}')\n",
    "\n",
    "train_ds = DevanagariDigitsDataset(tr_df, TRAIN_DIR, transform=train_tfm, has_labels=True)\n",
    "val_ds   = DevanagariDigitsDataset(va_df, TRAIN_DIR, transform=eval_tfm,  has_labels=True)\n",
    "test_ds  = DevanagariDigitsDataset(test_df, TEST_DIR, transform=eval_tfm, has_labels=False)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True)\n",
    "val_loader   = DataLoader(val_ds,   batch_size=BATCH_SIZE, shuffle=False,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True)\n",
    "test_loader  = DataLoader(test_ds,  batch_size=BATCH_SIZE, shuffle=False,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True)\n"
   ]
  },
  {
