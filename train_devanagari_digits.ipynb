   "source": [
    "## 5. Model Selection - CNN and MiniResNet\n",
    "\n",
    "The original baseline CNN is kept as a reference model. A stronger MiniResNet architecture is also added with residual connections, dropout, and batch normalization.\n",
    "\n",
    "The active model can be changed with the `MODEL_NAME` variable.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Trainable params: 140,778\n"
     ]
    }
   ],
   "source": [
    "class DigitCNN(nn.Module):\n",
    "    \"\"\"\n",
    "    Baseline convolutional neural network for 32x32 grayscale digit images.\n",
    "    This model is kept as the original reference architecture.\n",
    "    \"\"\"\n",
    "    def __init__(self, num_classes=10):\n",
    "        super().__init__()\n",
    "        self.features = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, 3, padding=1), nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(32, 32, 3, padding=1), nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n",
    "            nn.MaxPool2d(2),\n",
    "\n",
    "            nn.Conv2d(32, 64, 3, padding=1), nn.BatchNorm2d(64), nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(64, 64, 3, padding=1), nn.BatchNorm2d(64), nn.ReLU(inplace=True),\n",
    "            nn.MaxPool2d(2),\n",
    "\n",
    "            nn.Conv2d(64, 128, 3, padding=1), nn.BatchNorm2d(128), nn.ReLU(inplace=True),\n",
    "            nn.AdaptiveAvgPool2d(1),\n",
    "        )\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(128, num_classes),\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.features(x)\n",
    "        return self.classifier(x)\n",
    "\n",
    "\n",
    "class ResidualBlock(nn.Module):\n",
    "    \"\"\"\n",
    "    Residual block used in the MiniResNet model.\n",
    "    Shortcut connections help preserve low-level stroke information.\n",
    "    \"\"\"\n",
    "    def __init__(self, in_channels, out_channels, stride=1, dropout=0.1):\n",
    "        super().__init__()\n",
    "\n",
    "        self.conv_block = nn.Sequential(\n",
    "            nn.Conv2d(in_channels, out_channels, kernel_size=3, stride=stride, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(out_channels),\n",
    "            nn.ReLU(inplace=True),\n",
    "\n",
    "            nn.Conv2d(out_channels, out_channels, kernel_size=3, stride=1, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(out_channels),\n",
    "        )\n",
    "\n",
    "        self.shortcut = nn.Sequential()\n",
    "        if stride != 1 or in_channels != out_channels:\n",
    "            self.shortcut = nn.Sequential(\n",
    "                nn.Conv2d(in_channels, out_channels, kernel_size=1, stride=stride, bias=False),\n",
    "                nn.BatchNorm2d(out_channels),\n",
    "            )\n",
    "\n",
    "        self.relu = nn.ReLU(inplace=True)\n",
    "        self.dropout = nn.Dropout2d(dropout)\n",
    "\n",
    "    def forward(self, x):\n",
    "        out = self.conv_block(x)\n",
    "        out = out + self.shortcut(x)\n",
    "        out = self.relu(out)\n",
    "        out = self.dropout(out)\n",
    "        return out\n",
    "\n",
    "\n",
    "class MiniResNet(nn.Module):\n",
    "    \"\"\"\n",
    "    Lightweight ResNet-style CNN for Devanagari digit classification.\n",
    "    This model is deeper than the baseline CNN and uses residual connections\n",
    "    to improve feature learning on small 32x32 grayscale images.\n",
    "    \"\"\"\n",
    "    def __init__(self, num_classes=10):\n",
    "        super().__init__()\n",
    "\n",
    "        self.stem = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, kernel_size=3, stride=1, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(32),\n",
    "            nn.ReLU(inplace=True),\n",
    "        )\n",
    "\n",
    "        self.layers = nn.Sequential(\n",
    "            ResidualBlock(32, 32, stride=1, dropout=0.05),\n",
    "            ResidualBlock(32, 64, stride=2, dropout=0.10),\n",
    "            ResidualBlock(64, 64, stride=1, dropout=0.10),\n",
    "\n",
    "            ResidualBlock(64, 128, stride=2, dropout=0.15),\n",
    "            ResidualBlock(128, 128, stride=1, dropout=0.15),\n",
    "\n",
    "            ResidualBlock(128, 256, stride=2, dropout=0.20),\n",
    "        )\n",
    "\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.AdaptiveAvgPool2d(1),\n",
    "            nn.Flatten(),\n",
    "            nn.Dropout(0.35),\n",
    "            nn.Linear(256, num_classes),\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.stem(x)\n",
    "        x = self.layers(x)\n",
    "        x = self.classifier(x)\n",
    "        return x\n",
    "\n",
    "\n",
    "MODEL_NAME = \\"cnn\\"  # options: \"cnn\", \"miniresnet\"\n",
    "\n",
    "if MODEL_NAME == \"cnn\":\n",
    "    model = DigitCNN(NUM_CLASSES).to(DEVICE)\n",
    "elif MODEL_NAME == \"miniresnet\":\n",
    "    model = MiniResNet(NUM_CLASSES).to(DEVICE)\n",
    "else:\n",
    "    raise ValueError(f\"Unknown model name: {MODEL_NAME}\")\n",
    "\n",
    "n_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f\"Using model: {MODEL_NAME}\")\n",
    "print(f\"Trainable params: {n_params:,}\")\n",
    "print(model)\n"
   ]
  },
  {
